# Normalize line endings by default
* text=auto eol=lf

# Windows scripts / solution files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.sln text eol=crlf
*.vcxproj text eol=crlf
*.props text eol=crlf

# Common binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.pdf binary
*.zip binary
*.7z binary
*.rar binary
*.wav binary
*.mp3 binary
*.onnx binary
*.pt binary
*.pth binary
*.ckpt binary
*.bin binary
